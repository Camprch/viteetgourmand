APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_STRONG_SECRET
DEFAULT_URI=https://app.viteetgourmand.example

DATABASE_URL="mysql://APP_USER:APP_PASSWORD@DB_HOST:3306/viteetgourmand?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
MONGODB_URL="mongodb://MONGO_USER:MONGO_PASSWORD@MONGO_HOST:27017"
MONGODB_DB="viteetgourmand_stats"

# Keep doctrine transport for compatibility with current config even if mail is sync in prod
MESSENGER_TRANSPORT_DSN="doctrine://default?auto_setup=0"

# Option A (stable demo/no SMTP delivery): keep null transport
# MAILER_DSN="null://null"
# CONTACT_RECIPIENT="contact@viteetgourmand.local"
# CONTACT_SENDER="no-reply@viteetgourmand.local"

# Option B (real delivery for evaluator smoke tests): use SMTP provider
MAILER_DSN="smtp://SMTP_USER:SMTP_PASSWORD@SMTP_HOST:587?encryption=tls&auth_mode=login"
CONTACT_RECIPIENT="contact@viteetgourmand.fr"
CONTACT_SENDER="no-reply@viteetgourmand.fr"
