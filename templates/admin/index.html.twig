{% extends 'base.html.twig' %}

{% block title %}Espace admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-chart-wrap {
            overflow-x: auto;
        }
        .admin-chart {
            display: block;
            width: 100%;
            min-width: 720px;
            height: auto;
            border: 1px solid #d8cdbd;
            border-radius: 12px;
            background: #fffdf8;
        }
        .admin-chart-caption {
            margin-top: 8px;
            color: #6b645b;
            font-size: 0.95rem;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Espace Administrateur</h1>
    <p>Gestion des comptes employes.</p>

    <p><a href="{{ path('app_admin_employee_new') }}">Creer un compte employe</a></p>

    <h2>Employes</h2>
    {% if employees is empty %}
        <p class="muted">Aucun employe pour le moment.</p>
    {% else %}
        <ul aria-label="Liste des employes">
        {% for employee in employees %}
            <li>
                <article class="card">
                    <h3>{{ employee.email }}</h3>
                    <p>Actif: {{ employee.actif ? 'Oui' : 'Non' }}</p>
                    <p>Cree le: {{ employee.createdAt|date('d/m/Y H:i') }}</p>
                    <form method="post" action="{{ path('app_admin_employee_toggle_active', {id: employee.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_employee_' ~ employee.id) }}">
                        <button type="submit">{{ employee.actif ? 'Desactiver' : 'Activer' }}</button>
                    </form>
                </article>
            </li>
        {% endfor %}
        </ul>
    {% endif %}

    <h2>Dashboard commandes (MongoDB)</h2>
    {% if ordersByMenu is empty %}
        <p class="muted">Aucune donnee analytics disponible pour le moment.</p>
    {% else %}
        <p class="muted">Comparatif du nombre de commandes par menu.</p>
        {% set chartWidth = 860 %}
        {% set topPad = 24 %}
        {% set leftPad = 54 %}
        {% set bottomPad = 42 %}
        {% set rowHeight = 34 %}
        {% set barHeight = 18 %}
        {% set chartHeight = topPad + bottomPad + (ordersByMenu|length * rowHeight) %}
        {% set plotWidth = chartWidth - leftPad - 20 %}
        <div class="admin-chart-wrap card">
            <svg
                class="admin-chart"
                viewBox="0 0 {{ chartWidth }} {{ chartHeight }}"
                role="img"
                aria-label="Graphique comparatif du nombre de commandes par menu"
            >
                <line x1="{{ leftPad }}" y1="{{ topPad }}" x2="{{ leftPad }}" y2="{{ chartHeight - bottomPad }}" stroke="#cabfab" />
                <line x1="{{ leftPad }}" y1="{{ chartHeight - bottomPad }}" x2="{{ chartWidth - 16 }}" y2="{{ chartHeight - bottomPad }}" stroke="#cabfab" />
                {% for row in ordersByMenu %}
                    {% set y = topPad + (loop.index0 * rowHeight) + 6 %}
                    {% set barWidth = maxOrders > 0 ? ((row.commandes * plotWidth) / maxOrders)|round(0, 'floor') : 0 %}
                    <text x="12" y="{{ y + 12 }}" fill="#554d42" font-size="11">{{ loop.index }}</text>
                    <rect x="{{ leftPad + 1 }}" y="{{ y }}" width="{{ barWidth }}" height="{{ barHeight }}" rx="4" fill="#b3541e" />
                    <text x="{{ leftPad + barWidth + 8 }}" y="{{ y + 13 }}" fill="#2c2924" font-size="12">{{ row.commandes }}</text>
                    <text x="{{ leftPad + 6 }}" y="{{ y - 2 }}" fill="#6d6459" font-size="11">{{ row.menu_titre|slice(0, 58) }}</text>
                {% endfor %}
                <text x="{{ chartWidth - 40 }}" y="{{ chartHeight - 12 }}" fill="#6d6459" font-size="11">max: {{ maxOrders }}</text>
            </svg>
            <p class="admin-chart-caption">Chaque barre represente le nombre de commandes par menu (projection MongoDB).</p>
        </div>
    {% endif %}

    <h2>Chiffre d'affaires par menu</h2>
    <form method="get" action="{{ path('app_admin_dashboard') }}" class="card">
        <div>
            <label for="menu_id">Menu</label>
            <select id="menu_id" name="menu_id">
                <option value="">Tous les menus</option>
                {% for menu in menus %}
                    <option value="{{ menu.id }}" {% if filters.menu_id == menu.id %}selected{% endif %}>{{ menu.titre }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="date_from">Date debut</label>
            <input id="date_from" type="date" name="date_from" value="{{ filters.date_from }}">
        </div>
        <div>
            <label for="date_to">Date fin</label>
            <input id="date_to" type="date" name="date_to" value="{{ filters.date_to }}">
        </div>
        <button type="submit">Appliquer filtres</button>
    </form>

    {% if revenueByMenu is empty %}
        <p class="muted">Aucune commande sur ce filtre.</p>
    {% else %}
        <ul aria-label="Chiffre d'affaires par menu">
        {% for row in revenueByMenu %}
            <li>
                <article class="card">
                    <h3>{{ row.menu_titre }}</h3>
                    <p>Commandes: {{ row.commandes }}</p>
                    <p>CA: {{ (row.chiffre_affaires_centimes / 100)|number_format(2, ',', ' ') }} EUR</p>
                </article>
            </li>
        {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
