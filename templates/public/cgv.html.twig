{% extends 'base.html.twig' %}

{% block title %}CGV - Vite & Gourmand{% endblock %}

{% block body %}
    <h1>Conditions generales de vente</h1>

    <section class="card">
        <h2>Commande</h2>
        <p>La commande est validee apres confirmation et passage au statut "accepte" par l'equipe.</p>
    </section>

    <section class="card">
        <h2>Livraison</h2>
        <p>Livraison hors Bordeaux: forfait 5 EUR + 0,59 EUR par kilometre.</p>
    </section>

    <section class="card">
        <h2>Pret de materiel</h2>
        <p>En cas de non-retour du materiel sous 10 jours ouvres, une penalite de 600 EUR peut etre appliquee.</p>
    </section>
{% endblock %}
